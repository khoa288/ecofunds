    "@mui/material": "^5.12.1",
    "@solana/wallet-adapter-phantom": "^0.9.24",
    "@solana/web3.js": "^1.88.0",
    "@toruslabs/solana-embed": "^2.0.0",
    "aos": "^2.3.4",
    "axios": "^1.6.5",
    "bs58": "^5.0.0",
    "buffer": "^6.0.3",
    "card-validator": "^8.1.1",
    "crypto-browserify": "3.12.0",
    "crypto-random-string": "^3.3.0",
    "formik": "^2.2.9",
